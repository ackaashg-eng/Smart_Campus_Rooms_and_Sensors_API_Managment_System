<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Smart Campus API</display-name>

    <!--
        This file tells Tomcat how to wire up the application.
        Instead of a Main.java that starts the server manually,
        Tomcat reads this file on startup and knows:
          1. Which servlet to use (Jersey's ServletContainer)
          2. Which JAX-RS Application class to load
          3. Which URL pattern to map it to
    -->

    <servlet>
        <servlet-name>SmartCampusServlet</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>

        <!-- Tell Jersey which Application class to load -->
        <init-param>
            <param-name>javax.ws.rs.Application</param-name>
            <param-value>com.smartcampus.SmartCampusApplication</param-value>
        </init-param>

        <!-- Start this servlet immediately when Tomcat starts -->
        <load-on-startup>1</load-on-startup>
    </servlet>

    <!-- Map all requests under /api/v1/ to the Jersey servlet -->
    <servlet-mapping>
        <servlet-name>SmartCampusServlet</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>
